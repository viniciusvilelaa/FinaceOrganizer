generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int           @id @default(autoincrement())
  name         String
  email        String        @unique
  passwordHash String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  transactions Transaction[]
  financialGoal FinancialGoal[]
}

model Transaction {
  id          Int      @id @default(autoincrement())
  amount      Float
  type        String
  category    TransactionCategory
  description String
  date        DateTime

  userId Int
  user   User   @relation(fields: [userId], references: [id])
}

enum TransactionCategory {
  COMIDA
  TRANSPORTE
  LAZER
  SAUDE
  EDUCACAO
  MORADIA
  OUTROS
  INVESTIMENTO
  SALARIO
  ASSINATURAS
  COMBUSTIVEL
}

model FinancialGoal{
  id Int @id @default(autoincrement())
  name         String
  targetAmount Float
  month        Int
  year         Int
  createdAt    DateTime @default(now())
  
  userId Int
  user User @relation(fields: [userId], references: [id])

  @@unique([userId, month, year])
  @@unique([id, userId])
}
